{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "etf-arena-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-01",
  "observability": { "enabled": true },
  "workers_dev": true,
  // Top-level vars are the default for every deploy. When feature-branch /
  // preview web origins exist, add `env.<name>.vars.WEB_ORIGIN` here to
  // allow CORS for those origins.
  "vars": {
    "WEB_ORIGIN": "https://etf-arena-web.valuecodes.workers.dev",
  },
}
