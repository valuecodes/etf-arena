# Cloudflare Workers Assets reads this file at deploy time and applies the
# matching headers to every response that the asset server (not the SSR
# worker) emits. Astro's middleware never runs for these paths.

# Hashed asset bundles (Astro JS chunks, CSS, fonts). The filename embeds a
# content hash, so a stale cached copy can never be wrong — long-cache them
# and tell the browser not to revalidate.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Static files in /public/ that don't have a content hash. One day is a
# safe default — short enough that a deploy propagates within a day, long
# enough to avoid hammering the edge for things like the favicon.
/favicon.svg
  Cache-Control: public, max-age=86400
